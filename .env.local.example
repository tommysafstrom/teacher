# Copy this file to app/.env.local and fill in real values.

# Base URL for deep links in notification emails
APP_BASE_URL=http://localhost:3000

# Gmail SMTP — omit SMTP_HOST entirely to disable email (safe for local dev without credentials)
# To get an App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tommy.safstrom@gmail.com
SMTP_PASS=                          # paste Gmail App Password here (16 chars, no spaces)
